{
  "name": "@sketchmark/diagram-wireframe",
  "version": "0.0.2",
  "description": "Wireframe primitives for Sketchmark. Compiles lightweight wf.* commands into standard Sketchmark nodes and groups.",
  "keywords": [
    "@sketchmark/diagram",
    "plugin",
    "wireframe",
    "ui",
    "mockup",
    "diagram"
  ],
  "author": "sketchmark contributors",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@sketchmark/diagram": "^0.0.1"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/anmism/sketchmark"
  },
  "bugs": {
    "url": "https://github.com/anmism/sketchmark/issues"
  },
  "homepage": "https://github.com/anmism/sketchmark#readme"
}
