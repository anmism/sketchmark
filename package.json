{
  "name": "sketchmark",
  "version": "0.1.2",
  "description": "Convert AI-friendly DSL text into beautiful hand-drawn diagrams using rough.js. Supports SVG, Canvas, animations, and export.",
  "keywords": [
    "diagram",
    "dsl",
    "rough.js",
    "hand-drawn",
    "ai",
    "llm",
    "visualization",
    "animation",
    "svg"
  ],
  "author": "sketchmark contributors",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "roughjs": "^4.6.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "happy-dom": "^13.6.0",
    "rollup": "^4.9.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/bapunhansdah/sketchmark"
  },
  "bugs": {
    "url": "https://github.com/bapunhansdah/sketchmark/issues"
  },
  "homepage": "https://github.com/bapunhansdah/sketchmark#readme"
}
